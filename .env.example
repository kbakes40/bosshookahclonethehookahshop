# Client (Vite) — required for login and PostgREST from the browser.
# Supabase Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# Canonical public site origin (no trailing slash). Used for:
# - Google OAuth / magic-link redirectTo base (see client/src/lib/authRedirect.ts)
# - index.html canonical + Open Graph / Twitter URLs (build-time; vite.inject-site-meta.ts)
#   iMessage / link previews need this to match the URL you share, or og:image will point at the wrong host.
# Production (this deployment): use the exact origin you ship (no trailing slash).
# VITE_SITE_ORIGIN=https://www.davincidynamics.site
# If you use apex-only, use https://davincidynamics.site and match Plaid redirect + OAuth settings to the same host.
# Omit locally unless you need correct preview tags; Vercel can inject VERCEL_URL at build — still set this for canonical previews.

# Optional — defaults to https://pahukiygqfdxinpwoeee.supabase.co in shared/const.ts
# VITE_SUPABASE_URL=
# Serverless hosts (e.g. Vercel) often use the name from Supabase docs — same project URL as above:
# SUPABASE_URL=

# Server — service role; keep secret; used for admin JWT verification and server writes
# SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Console → OAuth 2.0 client → Authorized redirect URIs (exact):
# https://pahukiygqfdxinpwoeee.supabase.co/auth/v1/callback
# (also exported as SUPABASE_OAUTH_REDIRECT_URI in shared/const.ts)

# Admin inventory — Google Programmable Search (Custom Search JSON API)
# https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# Optional — comma-separated hostnames (no https); default 5starhookah.com
# COST_LOOKUP_SITES=

# Wholesale multi-source cost lookup (server-only; optional — 5star fallback works without these)
# SERPAPI_KEY=
# BARCODE_LOOKUP_KEY=

# Local API test only — scripts/test-api-route.js (Supabase access_token for an admin user)
# LOOKUP_TEST_BEARER=
# LOOKUP_TEST_ORIGIN=http://localhost:3000
#
# THS full-shop import (scripts/import-ths-shop-catalog.ts) — dry-run is default; --apply writes bh_products.
# Run supabase/migrations/011_bh_products_import_source.sql first so source_product_url + import_meta exist.
# pnpm import:ths-shop -- --report ./reports/ths-shop-dry-run.json
# pnpm import:ths-shop:apply -- --report ./reports/ths-shop-apply.json

# Plaid Transfer — Pay by Bank (server). Use Sandbox first.
# Dashboard: https://dashboard.plaid.com — create a Link customization with Account Select = one account (required for Transfer UI).
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# sandbox | production
# PLAID_ENV=sandbox
# Comma-separated (documentation / future use). Transfer UI uses product `transfer` in Link.
# PLAID_PRODUCTS=auth,transfer
# PLAID_COUNTRY_CODES=US
# Must match an Allowed redirect URI in Plaid Dashboard (HTTPS in production).
# Production (davincidynamics.site):
# PLAID_REDIRECT_URI=https://www.davincidynamics.site/plaid-oauth
# Local dev (add both localhost and production URIs in the Dashboard if you test both):
# PLAID_REDIRECT_URI=http://localhost:3000/plaid-oauth
# Optional; Transfer webhooks are often set in Dashboard instead.
# PLAID_WEBHOOK_URL=https://www.davincidynamics.site/api/plaid/webhook
# Display name in Link (max 30 chars).
# PLAID_TRANSFER_ORIGINATOR_NAME=The Hookah Shop
# Dashboard » Transfer » Accounts » Account ID (origination / funding account UUID).
# PLAID_FUNDING_ACCOUNT_ID=
# Link customization name from Dashboard (optional if `default` is configured for Transfer UI).
# PLAID_LINK_CUSTOMIZATION_NAME=
# Optional — for client-only debugging; not required for Link (token comes from server).
# VITE_PLAID_ENV=sandbox
