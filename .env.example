# Client (Vite) — required for login and PostgREST from the browser.
# Supabase Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# Optional — defaults to https://sjmrdnrneknzqiojtevm.supabase.co in shared/const.ts
# VITE_SUPABASE_URL=
# Serverless hosts (e.g. Vercel) often use the name from Supabase docs — same project URL as above:
# SUPABASE_URL=

# Server — service role; keep secret; used for admin JWT verification and server writes
# SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Console → OAuth 2.0 client → Authorized redirect URIs (exact):
# https://sjmrdnrneknzqiojtevm.supabase.co/auth/v1/callback
# (also exported as SUPABASE_OAUTH_REDIRECT_URI in shared/const.ts)

# Admin inventory — Google Programmable Search (Custom Search JSON API)
# https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# Optional — comma-separated hostnames (no https); default 5starhookah.com
# COST_LOOKUP_SITES=

# Wholesale multi-source cost lookup (server-only; optional — 5star fallback works without these)
# SERPAPI_KEY=
# BARCODE_LOOKUP_KEY=

# Local API test only — scripts/test-api-route.js (Supabase access_token for an admin user)
# LOOKUP_TEST_BEARER=
# LOOKUP_TEST_ORIGIN=http://localhost:3000
