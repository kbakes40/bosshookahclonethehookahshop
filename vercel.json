{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm vite build --config vite.vercel.config.ts && node_modules/.bin/esbuild server/_vercel_exports.ts --platform=node --packages=external --bundle --format=esm --outfile=api/_server.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thehookahshop.com" }],
      "destination": "https://www.thehookahshop.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bosshookah.site" }],
      "destination": "https://www.bosshookah.site/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "davincidynamics.site" }],
      "destination": "https://www.davincidynamics.site/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|\\.well-known/|assets/|images/|products/|__manus__/|favicon|site\\.webmanifest|robots\\.txt|sitemap|og-image\\.png|apple-touch|android-chrome-|web-app-manifest-|hookah-brand|brand-icon\\.png).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "api/_server.mjs"
    }
  }
}
